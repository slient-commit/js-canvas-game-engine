              "position": { "X": 320, "Y": 70 },
              "velocity": { "X": 0, "Y": 0 },
              "opacity": 1,
              "showIt": true,
              "isStatic": false,
              "sprite": { "type": "sprite", "width": 32, "height": 32, "path": "assets/sprites/enemy.png" }

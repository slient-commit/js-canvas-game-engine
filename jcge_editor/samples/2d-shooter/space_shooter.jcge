              "type": "element",
              "name": "Star5",
              "position": { "X": 400, "Y": 450 },
              "opacity": 0.7,
              "showIt": true,
              "sprite": { "type": "sprite", "width": 4, "height": 4, "path": "assets/sprites/star.png" }
            },
            {
              "id": "el_go_star6",
              "type": "element",
              "name": "Star6",
              "position": { "X": 280, "Y": 520 },
              "opacity": 0.3,
              "showIt": true,
              "sprite": { "type": "sprite", "width": 4, "height": 4, "path": "assets/sprites/star.png" }
            }
          ]
        },
        {
          "id": "layer_go_ui",
          "name": "ui",
          "zOrder": 10,
          "isUI": true,
          "gameObjects": [],
          "elements": []
        }
      ],
      "script": {
        "onCreate": "var data = this.getIncomingData();\nthis.finalScore = (data && data.score) ? data.score : 0;\n\nvar uiLayer = this.layers[this.layers.length - 1].layer;\n\nvar goLabel = new UILabel('GAME OVER', new Vec2(110, 250), { fontSize: 40, color: '#ff4444' });\nuiLayer.registerElement(goLabel);\n\nvar scoreLabel = new UILabel('Score: ' + this.finalScore, new Vec2(170, 300), { fontSize: 24, color: 'white' });\nuiLayer.registerElement(scoreLabel);\n\nvar restartLabel = new UILabel('Press SPACE to Play Again', new Vec2(110, 370), { fontSize: 14, color: '#aaaaaa' });\nuiLayer.registerElement(restartLabel);",
        "onUpdate": "var W = 480;\nvar H = 640;\n\nvar stars = ['Star1', 'Star2', 'Star3', 'Star4', 'Star5', 'Star6'];\nfor (var i = 0; i < stars.length; i++) {\n  var s = this.findByName(stars[i]);\n  if (!s) continue;\n  s.position.Y += (20 + i * 8) * elapsedTime;\n  if (s.position.Y > H) s.position.Y = -4;\n}\n\nif (engine.input.isKeyPressed(Keys.Space)) {\n  for (var i = 0; i < engine.scenes.length; i++) {\n    if (engine.scenes[i].name === 'GameScene') {\n      engine.goToScene(engine.scenes[i], null, 'fade', 0.5);\n      break;\n    }\n  }\n}",
        "onDestroy": ""
      }
    }
  ],
